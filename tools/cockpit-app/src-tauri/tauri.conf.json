{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "1C AI Cockpit",
  "version": "0.1.0",
  "identifier": "io.github.timoshinoleg-eng.onec-ai-cockpit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "1C AI Cockpit",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "1c-ai-workbench contributors",
    "category": "DeveloperTool",
    "shortDescription": "Local GUI for 1C AI Workbench",
    "longDescription": "1C AI Cockpit is a local desktop wrapper for the 1C AI Workbench. It spawns the bundled MCP servers (1c-code-index, 1c-skills, 1c-prompt-gallery, 1c-help-index, 1c-ibcmd) as child processes over stdio and exposes a clean web UI for non-AI tasks: status, search, help browser, risk scan, and settings. All processing is local; no data leaves the machine unless an external LLM is configured by the operator.",
    "homepage": "https://github.com/timoshinoleg-eng/1c-ai-workbench",
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": true,
      "wix": {
        "language": ["ru-RU", "en-US"]
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "languages": ["Russian", "English"]
      }
    },
    "resources": {
      "../embedded-resources/tools/code-index-mcp/target/release/bsl-indexer.exe": "tools/code-index-mcp/target/release/bsl-indexer.exe",
      "../embedded-resources/tools/skills-bridge": "tools/skills-bridge",
      "../embedded-resources/tools/prompt-gallery": "tools/prompt-gallery",
      "../embedded-resources/tools/help-index-mcp": "tools/help-index-mcp",
      "../embedded-resources/configs/opencode-mcp.jsonc": "configs/opencode-mcp.jsonc"
    },
    "externalBin": [],
    "copyright": "Copyright (c) 2026 1c-ai-workbench contributors",
    "licenseFile": "../../../LICENSE"
  },
  "plugins": {}
}
