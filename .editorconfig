root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{rs,toml}]
indent_size = 4
max_line_length = 100

[*.ps1]
indent_size = 4
end_of_line = crlf

[*.psm1]
indent_size = 4
end_of_line = crlf

[*.psd1]
indent_size = 4
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
