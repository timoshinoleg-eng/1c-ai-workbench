{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "description": "Schema for risk-rules.json — BSL heuristic rules",
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "name", "pattern", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "threshold": { "type": "integer" },
          "pattern": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    }
  }
}
